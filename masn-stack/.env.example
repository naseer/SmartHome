# Copy to .env and fill real values. Then: chmod 600 .env. NEVER commit real secrets.

TZ=America/Toronto

# --- Postgres (HA recorder DB) ---
PG_USER=hauser
PG_PASSWORD=CHANGE_ME_strong_random

# --- Mosquitto MQTT user (shared by HA + Zigbee2MQTT) ---
# setup-masn.sh writes this into mosquitto/config/passwd via mosquitto_passwd.
MQTT_USER=mqtt
MQTT_PASSWORD=CHANGE_ME_strong_random

# --- Frigate (Phase 3) ---
FRIGATE_RTSP_PASSWORD=CHANGE_ME_strong_random

# --- NAS (fill once the NAS is up tomorrow) ---
NAS_IP=192.168.x.x
# NFS export paths AS THE NAS EXPORTS THEM (TrueNAS: /mnt/<pool>/<share>; UGOS differs)
NAS_MEDIA_EXPORT=/mnt/pool/media
NAS_FRIGATE_EXPORT=/mnt/pool/frigate
NAS_BACKUPS_EXPORT=/mnt/pool/backups
